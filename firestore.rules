rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read and write everything (for development)
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Explicitly allow insights collection
    match /insights/{personId}/timestamps/{transcriptId} {
      allow read, write: if true;
    }
  }
} 